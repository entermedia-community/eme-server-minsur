<page>
  <path-action name="JsonDataModule.preprocess" />
  <path-action bean="jsonUtil" name="PageValue.loadPageVariable" allowduplicates="true"/>
  <property name="alternative_extension">json</property>
  <generator name="velocityGenerator" mimetypes="text/html"/>
  <generator name="velocityGenerator" mimetypes="text/json"/>

  <path-action name="ChatModule.loadChannelChat" alltypes="true"/>
</page>